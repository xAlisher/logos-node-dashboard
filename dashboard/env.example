# Copy to .env or export these values before running dashboard/run.sh.

HOST=127.0.0.1
PORT=8090
NODE_API=http://127.0.0.1:8080

# Path to the Logos node file logs. The default assumes this runbook layout.
NODE_LOG_DIR=state/live-v0.1.2/logs

# Path to zone-board state. This contains private keys, so do not commit it.
ZONE_BOARD_DIR=state/zone-board-v0.2.2
ZONE_BOARD_TMUX_SESSION=zone-board

# Human channel name passed to zone-board with --channel.
ZONE_CHANNEL=your-channel
